#. Plugin Name of the plugin
#: followup.php
msgid "Followup - Order Follow-Up Emails for WooCommerce"
msgstr "Followup - Wiadomości posprzedażowe dla WooCommerce"

#. Plugin URI of the plugin
#: followup.php
msgid "https://plogins.com/followup/"
msgstr "https://plogins.com/followup/"

#. Description of the plugin
#: followup.php
msgid "Send automated post-purchase emails to WooCommerce customers: thank-you and review requests, a set number of days after an order."
msgstr "Wysyłaj automatyczne wiadomości posprzedażowe do klientów WooCommerce: podziękowania i prośby o opinię, określoną liczbę dni po złożeniu zamówienia."

#. Author of the plugin
#: followup.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: followup.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: followup.php:65
msgid "Followup - Order Follow-Up Emails for WooCommerce requires WooCommerce to be active."
msgstr "Followup - Wiadomości posprzedażowe dla WooCommerce wymaga aktywnej wtyczki WooCommerce."

#: src/Admin/SettingsPage.php:40
msgid "Follow-up Emails"
msgstr "Wiadomości posprzedażowe"

#: src/Admin/SettingsPage.php:41
msgid "Follow-ups"
msgstr "Wiadomości posprzedażowe"

#: src/Admin/SettingsPage.php:95
msgid "Active"
msgstr "Aktywne"

#: src/Admin/SettingsPage.php:97
msgid "No emails enabled"
msgstr "Brak włączonych wiadomości"

#: src/Admin/SettingsPage.php:104
msgid "Automated post-purchase emails"
msgstr "Automatyczne wiadomości posprzedażowe"

#: src/Admin/SettingsPage.php:105
msgid "Each enabled email is sent once per order, a set number of days after the order reaches the chosen status. A daily background task finds due orders and sends them. The same email is never sent twice for the same order."
msgstr "Każda włączona wiadomość jest wysyłana raz na zamówienie, określoną liczbę dni po osiągnięciu przez zamówienie wybranego statusu. Codzienne zadanie w tle wyszukuje zamówienia gotowe do wysyłki i realizuje ją. Ta sama wiadomość nigdy nie zostanie wysłana dwa razy dla tego samego zamówienia."

#: src/Admin/SettingsPage.php:113
msgid "Sender"
msgstr "Nadawca"

#: src/Admin/SettingsPage.php:114
msgid "Who follow-up emails appear to come from. Leave blank to use your store name and admin email."
msgstr "Od kogo mają pochodzić wiadomości posprzedażowe. Pozostaw puste, aby użyć nazwy sklepu i adresu e-mail administratora."

#: src/Admin/SettingsPage.php:119
msgid "From name"
msgstr "Nazwa nadawcy"

#: src/Admin/SettingsPage.php:125
msgid "The sender name shown in the customer's inbox. Defaults to your site name."
msgstr "Nazwa nadawcy wyświetlana w skrzynce odbiorczej klienta. Domyślnie nazwa Twojej witryny."

#: src/Admin/SettingsPage.php:130
msgid "From email"
msgstr "Adres e-mail nadawcy"

#: src/Admin/SettingsPage.php:136
msgid "The sender address. Defaults to your site admin email. Use an address on your own domain for the best deliverability."
msgstr "Adres nadawcy. Domyślnie adres e-mail administratora witryny. Aby zapewnić najlepszą dostarczalność, użyj adresu we własnej domenie."

#: src/Admin/SettingsPage.php:143
msgid "Available template tokens"
msgstr "Dostępne symbole zastępcze szablonu"

#: src/Admin/SettingsPage.php:144
msgid "Tokens you can use in subjects and bodies:"
msgstr "Symbole zastępcze, których możesz użyć w tematach i treściach:"

#: src/Admin/SettingsPage.php:161
msgid "Enabled"
msgstr "Włączone"

#: src/Admin/SettingsPage.php:170
msgid "Trigger status"
msgstr "Status wyzwalający"

#: src/Admin/SettingsPage.php:181
msgid "The email is scheduled once an order reaches this status."
msgstr "Wiadomość zostaje zaplanowana, gdy zamówienie osiągnie ten status."

#: src/Admin/SettingsPage.php:186
msgid "Delay (days)"
msgstr "Opóźnienie (dni)"

#: src/Admin/SettingsPage.php:194
msgid "days after the order reaches the status above"
msgstr "dni po osiągnięciu przez zamówienie powyższego statusu"

#: src/Admin/SettingsPage.php:195
msgid "Use 0 to send on the next daily run."
msgstr "Ustaw 0, aby wysłać przy następnym codziennym uruchomieniu."

#: src/Admin/SettingsPage.php:200
msgid "Subject"
msgstr "Temat"

#: src/Admin/SettingsPage.php:210
msgid "Body"
msgstr "Treść"

#: src/Admin/SettingsPage.php:215
msgid "Plain text. Tokens above are replaced when the email is sent."
msgstr "Zwykły tekst. Powyższe symbole zastępcze są podstawiane przy wysyłce wiadomości."

#: src/Admin/SettingsPage.php:295
msgid "Completed"
msgstr "Zrealizowane"

#: src/FollowupTypes.php:22
msgid "Thank-you"
msgstr "Podziękowanie"

#: src/FollowupTypes.php:23
msgid "A warm thank-you sent shortly after the order is fulfilled."
msgstr "Serdeczne podziękowanie wysyłane krótko po zrealizowaniu zamówienia."

#: src/FollowupTypes.php:26
msgid "Review request"
msgstr "Prośba o opinię"

#: src/FollowupTypes.php:27
msgid "Asks the customer to leave a review once they have had time with the product."
msgstr "Prosi klienta o wystawienie opinii, gdy zdąży już zapoznać się z produktem."

#: src/Service/Mailer.php:64
msgid "there"
msgstr "Drogi Kliencie"
